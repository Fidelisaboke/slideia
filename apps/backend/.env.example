ENVIRONMENT=development

# Frontend URL
NEXT_FRONTEND_URL=http://localhost:3000

# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO

# Unsplash
UNSPLASH_ACCESS_KEY=

# Generation
MAX_CONCURRENT_LLM_CALLS=2
